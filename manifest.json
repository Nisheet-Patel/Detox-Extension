{
  "manifest_version": 3,
  "name": "Detox",
  "version": "0.0.2",
  "description": "",
  "background": {
    "service_worker": "/src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "js": [
        "src/content/youtube.js"
      ]
    },
    {
      "matches": [
        "*://www.instagram.com/*"
      ],
      "js": [
        "src/content/instagram.js"
      ]
    }
  ],
  "action": {
    "default_popup": "src/ui/popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "idle"
  ]
}