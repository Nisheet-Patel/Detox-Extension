{
  "manifest_version": 3,
  "name": "Detox",
  "version": "0.0.1",
  "description": "",
  
  "background": {
    "service_worker": "/src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "permissions": [
    "activeTab",      
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ]
}